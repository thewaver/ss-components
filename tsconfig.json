{
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ESNext",
        "strict": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,

        "noUnusedParameters": false,
        "noEmit": true
    },
    "include": ["src"]
}
