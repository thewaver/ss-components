{
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ESNext",
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@ss-components/*": ["src/Lib/*"]
        },
        "declaration": true,
        "outDir": "dist"
    },
    "include": ["src/Lib", "src/Playground"]
}
