{
    "name": "@thewaver/ss-components",
    "type": "module",
    "version": "0.0.1",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "license": "MIT",
    "scripts": {
        "build:lib": "tsup src/Lib/index.ts --format esm --dts --clean",
        "build:playground": "vite build --config ./vite.config.ts",
        "build:all": "npm run build:lib && npm run build:playground",
        "dev": "tsup src/Lib/index.ts --format esm --dts --watch",
        "preview": "vite preview --config ./vite.config.ts",
        "start": "vite --config ./vite.config.ts --host",
        "format": "prettier --write ."
    },
    "dependencies": {
        "colorthief": "^3.4.0",
        "shiki": "^4.3.1"
    },
    "devDependencies": {
        "@solidjs/router": "^0.16.2",
        "@thewaver/ss-utils": "^0.0.15",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@vanilla-extract/css": "^1.21.1",
        "@vanilla-extract/dynamic": "^2.1.5",
        "@vanilla-extract/vite-plugin": "^5.2.5",
        "prettier": "^3.9.5",
        "solid-js": "^1.9.14",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "vite": "^8.1.5",
        "vite-plugin-checker": "^0.14.4",
        "vite-plugin-solid": "^2.11.13"
    },
    "peerDependencies": {
        "@solidjs/router": "^0.16.2",
        "@thewaver/ss-utils": "^0.0.15",
        "solid-js": "^1.9.14"
    },
    "prettier": {
        "tabWidth": 4,
        "printWidth": 120,
        "quoteProps": "consistent",
        "plugins": [
            "@trivago/prettier-plugin-sort-imports"
        ],
        "importOrder": [
            "^[a-z]",
            "^@",
            "^[./](?!.*\\.css$)",
            ".*\\.css$"
        ],
        "importOrderSeparation": true,
        "importOrderSortSpecifiers": true
    }
}
