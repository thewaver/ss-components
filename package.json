{
    "name": "@thewaver/ss-components",
    "type": "module",
    "version": "0.0.1",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "license": "MIT",
    "scripts": {
        "build": "tsup src/Lib/index.ts --format esm --dts --clean",
        "dev": "tsup --watch",
        "start": "vite --config ./vite.config.ts",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@chenglou/pretext": "^0.0.5",
        "colorthief": "^3.3.1"
    },
    "devDependencies": {
        "@thewaver/ss-utils": "^0.0.6",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@vanilla-extract/css": "^1.20.1",
        "@vanilla-extract/dynamic": "^2.1.5",
        "@vanilla-extract/vite-plugin": "^5.2.2",
        "fast-equals": "^6.0.0",
        "prettier": "^3.8.3",
        "solid-js": "^1.9.12",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-checker": "^0.13.0",
        "vite-plugin-solid": "^2.11.12"
    },
    "peerDependencies": {
        "@chenglou/pretext": "^0.0.5",
        "@thewaver/ss-utils": "^0.0.6",
        "fast-equals": "^6.0.0",
        "solid-js": "^1.9.12"
    },
    "prettier": {
        "tabWidth": 4,
        "printWidth": 120,
        "quoteProps": "consistent",
        "plugins": [
            "@trivago/prettier-plugin-sort-imports"
        ],
        "importOrder": [
            "^[a-z]",
            "^@",
            "^[./](?!.*\\.css$)",
            ".*\\.css$"
        ],
        "importOrderSeparation": true,
        "importOrderSortSpecifiers": true
    }
}
